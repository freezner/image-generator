# ========================================
# JB Bank Image Generator - .gitignore
# ========================================

# ========== 환경 설정 (민감 정보) ==========
.env
.env.local
.env.production
*.env

# ========== Python ==========
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.eggs/
*.egg-info/
*.egg

# 가상환경
venv/
.venv/
env/
ENV/

# ========== 빌드 결과물 ==========
# PyInstaller
build/
dist/
*.spec

# Flet build
.flet/

# ========== 출력 파일 ==========
output/
!output/.gitkeep

# ========== 사용자 에셋 ==========
# 캐릭터 이미지 (사용자별 다름)
assets/character/*.png
assets/character/*.jpg
assets/character/*.jpeg
assets/character/*.webp
!assets/character/.gitkeep

# 생성된 아이콘 (빌드 시 생성)
assets/icon.png
assets/icon.icns
assets/icon.ico
assets/icon_*.png
# SVG는 유지
!assets/icon.svg

# ========== IDE / 에디터 ==========
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.spyproject/

# ========== OS 생성 파일 ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ========== 로그 / 임시 파일 ==========
*.log
*.tmp
*.temp
*.bak
*~

# ========== 테스트 / 커버리지 ==========
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ========== 기타 ==========
*.dmg
*.zip
*.tar.gz
